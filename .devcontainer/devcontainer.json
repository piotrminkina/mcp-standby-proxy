{
  "name": "mcp-standby-proxy",
  "image": "python:3.12-slim",
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
  "workspaceFolder": "${localWorkspaceFolder}",
  "features": {
    "ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1.0": {
      "shellautocompletion": true,
      "version": "0.11.7"
    },
    "ghcr.io/devcontainers-extra/features/shellcheck:1.1": {
      "version": "0.11.0"
    },
    "ghcr.io/devcontainers/features/common-utils:2.5": {
      "installOhMyZsh": false,
      "installOhMyZshConfig": false,
      "installSsl": true,
      "installZsh": false,
      "upgradePackages": false,
      "username": "devcontainer"
    },
    "ghcr.io/devcontainers/features/git:1.3": {
      "version": "os-provided"
    },
    "ghcr.io/devcontainers/features/python:1.8": {
      "installTools": false,
      "version": "os-provided"
    }
  },
  "remoteUser": "devcontainer",
  "containerEnv": {
    "UV_LINK_MODE": "copy"
  },
  "postCreateCommand": "test -f pyproject.toml && uv sync || true"
}
